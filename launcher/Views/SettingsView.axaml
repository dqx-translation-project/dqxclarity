<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DqxClarity.Launcher.ViewModels"
             xmlns:m="using:DqxClarity.Launcher.Models"
             xmlns:v="using:DqxClarity.Launcher.Views"
             xmlns:svc="using:DqxClarity.Launcher.Services"
             x:Class="DqxClarity.Launcher.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Background="{DynamicResource AppBg}">

    <UserControl.Resources>
        <v:PatchProgressConverter x:Key="PatchProgress"/>
    </UserControl.Resources>

    <Grid ColumnDefinitions="148,*" RowDefinitions="*,54">

        <!-- ── Sidebar ───────────────────────────────────────────────── -->
        <Border Grid.Column="0" Grid.RowSpan="2"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="0,0,1,0"
                Padding="10,12">
            <Grid RowDefinitions="Auto,Auto,*,Auto">

                <!-- Theme selector -->
                <ComboBox Grid.Row="0"
                          x:Name="ThemeCombo"
                          HorizontalAlignment="Stretch"
                          SelectionChanged="OnThemeSelectionChanged"/>

                <!-- Server Status -->
                <StackPanel Grid.Row="1" Spacing="3" Margin="0,8,0,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="Server Status"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppMuted}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="Refresh"
                                       FontSize="10"
                                       Cursor="Hand"
                                       IsVisible="{Binding !RefreshOnCooldown}"
                                       Tapped="OnRefreshTapped"/>
                            <StackPanel Orientation="Horizontal" Spacing="2"
                                        IsVisible="{Binding RefreshOnCooldown}">
                                <TextBlock Text="{Binding RefreshCountdownText}"
                                           FontSize="10"
                                           Foreground="{DynamicResource AppMuted}"/>
                                <TextBlock Text="Refresh"
                                           FontSize="10"
                                           Foreground="{DynamicResource AppMuted}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <TextBlock IsVisible="{Binding CheckingMaintenance}"
                               Text="Checking..."
                               FontSize="11"
                               Foreground="{DynamicResource AppMuted}"/>
                    <TextBlock IsVisible="{Binding ServerIsUp}"
                               Text="● Game is online!"
                               FontSize="11"
                               Foreground="{DynamicResource AppSuccess}"/>
                    <TextBlock IsVisible="{Binding ServerIsDown}"
                               Text="● In maintenance"
                               FontSize="11"
                               Foreground="{DynamicResource AppDanger}"/>
                    <TextBlock IsVisible="{Binding ServerIsUnknown}"
                               Text="● Status unknown"
                               FontSize="11"
                               Foreground="{DynamicResource AppMuted}"/>
                    <TextBlock IsVisible="{Binding ServerIsDown}"
                               Text="{Binding ServerMessage}"
                               FontSize="10"
                               Foreground="{DynamicResource AppMuted}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Character mascot -->
                <Image Grid.Row="2"
                       Source="{Binding CharacterImage}"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="6,8"/>

                <!-- Footer links -->
                <StackPanel Grid.Row="3" Spacing="1">
                    <Button Classes="ghost" FontSize="15" Click="OnAboutClick">About</Button>
                    <Button Classes="ghost" FontSize="15" Click="OnWikiClick">Wiki</Button>
                    <Button Classes="ghost" FontSize="15" Click="OnSupportClick">Support</Button>
                    <TextBlock Text="{Binding Version, StringFormat='v{0}'}"
                               FontSize="15"
                               Foreground="{DynamicResource AppMuted}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Main content area ─────────────────────────────────────── -->
        <Grid Grid.Column="1" Grid.Row="0" RowDefinitions="Auto,*">

            <!-- Tab strip -->
            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,0,0,1"
                    Background="{DynamicResource AppSurface}">
                <StackPanel Orientation="Horizontal" Spacing="0">
                    <Button x:Name="TabGeneral"    Classes="tab" Click="OnTabClick" Tag="general">General</Button>
                    <Button x:Name="TabAdvanced"   Classes="tab" Click="OnTabClick" Tag="advanced">Advanced</Button>
                    <Button x:Name="TabOverrides"  Classes="tab" Click="OnTabClick" Tag="nameoverrides">Name Overrides</Button>
                    <Button x:Name="TabDatabase"   Classes="tab" Click="OnTabClick" Tag="database">Database</Button>
                    <Button x:Name="TabGame"       Classes="tab" Click="OnTabClick" Tag="game">Game</Button>
                    <Button x:Name="TabLanguagePacks" Classes="tab" Click="OnTabClick" Tag="languagepacks">Language Packs</Button>
                    <Button x:Name="TabText2Clipboard"  Classes="tab" Click="OnTabClick" Tag="text2clipboard">Text2Clipboard</Button>
                </StackPanel>
            </Border>

            <!-- Tab content area — all panels overlap; SwitchTab controls visibility -->
            <Grid Grid.Row="1">

                <!-- ── Scrollable panels (General / Advanced / Game) ──── -->
                <ScrollViewer x:Name="TabScroll"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="14,12">
                    <StackPanel MaxWidth="504">

                        <!-- ══ GENERAL TAB ══════════════════════════════ -->
                        <StackPanel x:Name="PanelGeneral" Spacing="14">
                            <TextBlock IsVisible="{Binding !DirectLogin}"
                                       Text="Native copy/paste support only works when &quot;Log into DQX directly with dqxclarity&quot; is enabled! This can be configured under Game > Launch."
                                       FontSize="11"
                                       Foreground="{DynamicResource AppDanger}"
                                       TextWrapping="Wrap"/>
                            <Border Classes="fieldset">
                                <StackPanel Spacing="0">
                                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,8">
                                        <TextBlock Classes="legend" Text="Configuration" Margin="0" VerticalAlignment="Center"/>
                                        <Button Classes="ghost" FontSize="11" Padding="2,0" VerticalAlignment="Center" Click="OnGeneralConfigHelpClick">?</Button>
                                    </StackPanel>
                                    <CheckBox Content="Nameplates"
                                              IsChecked="{Binding Nameplates}"
                                              ToolTip.Tip="Transliterates Japanese nameplates to English."/>
                                </StackPanel>
                            </Border>

                            <Border Classes="fieldset">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,0">
                                        <TextBlock Classes="legend" Text="API Settings" Margin="0" VerticalAlignment="Center"/>
                                        <Button Classes="ghost" FontSize="11" Padding="2,0" VerticalAlignment="Center" Click="OnGeneralApiHelpClick">?</Button>
                                    </StackPanel>

                                    <!-- Service selector -->
                                    <ComboBox x:Name="TranslateServiceCombo"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnTranslateServiceChanged"
                                              ToolTip.Tip="Select the translation service to use for untranslated game text."/>

                                    <!-- None service info -->
                                    <TextBlock IsVisible="{Binding IsNoneService}"
                                               Text="No server-side text translation will be performed."
                                               FontSize="11"
                                               Foreground="{DynamicResource AppMuted}"
                                               TextWrapping="Wrap"/>

                                    <!-- Free service warning -->
                                    <TextBlock IsVisible="{Binding IsFreeService}"
                                               Text="Free APIs are unstable, unreliable and tend to have a poor translation quality."
                                               FontSize="11"
                                               Foreground="{DynamicResource AppMuted}"
                                               TextWrapping="Wrap"/>

                                    <!-- API key (deepl, google, chatgpt, libretranslate) -->
                                    <TextBox IsVisible="{Binding ShowKeyField}"
                                             PasswordChar="•"
                                             Watermark="API Key"
                                             Text="{Binding TranslateKey}"
                                             ToolTip.Tip="API key for the selected translation service."/>

                                    <!-- ChatGPT model -->
                                    <TextBox IsVisible="{Binding ShowChatGptModel}"
                                             Watermark="Model (e.g. gpt-4o-mini)"
                                             Text="{Binding ChatGptModel}"
                                             ToolTip.Tip="The OpenAI model to use for translation."/>

                                    <!-- Ollama URL -->
                                    <TextBox IsVisible="{Binding ShowOllamaFields}"
                                             Watermark="Ollama URL (e.g. http://localhost:11434)"
                                             Text="{Binding OllamaUrl}"
                                             ToolTip.Tip="The base URL of your Ollama instance."/>

                                    <!-- Ollama model -->
                                    <TextBox IsVisible="{Binding ShowOllamaFields}"
                                             Watermark="Model name (e.g. llama3)"
                                             Text="{Binding OllamaModel}"
                                             ToolTip.Tip="The Ollama model to use for translation."/>

                                    <!-- LibreTranslate instance URL -->
                                    <TextBox IsVisible="{Binding ShowLibreTranslateUrl}"
                                             Watermark="Instance URL (e.g. https://libretranslate.com)"
                                             Text="{Binding LibreTranslateUrl}"
                                             ToolTip.Tip="URL of the LibreTranslate instance to use. Can be a self-hosted instance."/>

                                    <!-- Validate row (deepl and google only) -->
                                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0"
                                                IsVisible="{Binding ShowValidateButton}">
                                        <Button Command="{Binding ValidateKeyCommand}"
                                                IsEnabled="{Binding CanValidate}"
                                                ToolTip.Tip="Validate that the selected API key works."
                                                x:Name="ValidateBtn">Validate Key</Button>
                                        <TextBlock Text="{Binding StatusMsg}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource AppMuted}"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding StatusMsg, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ══ ADVANCED TAB ══════════════════════════════ -->
                        <StackPanel x:Name="PanelAdvanced" Spacing="14" IsVisible="False">
                            <Border Classes="fieldset">
                                <StackPanel Spacing="0">
                                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,8">
                                        <TextBlock Classes="legend" Text="Configuration" Margin="0" VerticalAlignment="Center"/>
                                        <Button Classes="ghost" FontSize="11" Padding="2,0" VerticalAlignment="Center" Click="OnAdvancedConfigHelpClick">?</Button>
                                    </StackPanel>
                                    <CheckBox Content="Community Logging"
                                              IsChecked="{Binding CommunityLogging}"
                                              ToolTip.Tip="Enables logging of internal game files to a text file."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="fieldset">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,0">
                                        <TextBlock Classes="legend" Text="Logging" Margin="0" VerticalAlignment="Center"/>
                                        <Button Classes="ghost" FontSize="11" Padding="2,0" VerticalAlignment="Center" Click="OnLoggingHelpClick">?</Button>
                                    </StackPanel>
                                    <CheckBox Content="Enable Debug Logging"
                                              IsChecked="{Binding DebugLogging}"
                                              ToolTip.Tip="Enables more verbose logging."/>
                                    <Button Command="{Binding OpenLogFolderCommand}"
                                            ToolTip.Tip="Open the logs folder in file explorer.">Open Log Folder</Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ══ GAME TAB ══════════════════════════════════ -->
                        <StackPanel x:Name="PanelGame" Spacing="0" IsVisible="False">

                            <!-- Game sub-tab strip — negative margin breaks out of ScrollViewer padding
                                 so it sits flush like the main tab strip above -->
                            <Border BorderBrush="{DynamicResource AppBorder}"
                                    BorderThickness="0,0,0,1"
                                    Background="{DynamicResource AppSurface}"
                                    Margin="-14,-12,-14,14">
                                <StackPanel Orientation="Horizontal" Spacing="0">
                                    <Button x:Name="GameTabInstall"
                                            Classes="tab"
                                            Tag="install"
                                            Click="OnGameSubTabClick">Install Configuration</Button>
                                    <Button x:Name="GameTabLaunch"
                                            Classes="tab"
                                            Tag="launch"
                                            Click="OnGameSubTabClick"
                                            IsEnabled="{Binding DqxDirValid}"
                                            ToolTip.Tip="Set a valid DQX folder path to access Launch settings.">Launch</Button>
                                </StackPanel>
                            </Border>

                            <!-- ── Install Configuration sub-panel ──────── -->
                            <StackPanel x:Name="PanelGameInstall" Spacing="14">

                                <Border Classes="fieldset">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,0">
                                            <TextBlock Classes="legend" Text="Installation" Margin="0" VerticalAlignment="Center"/>
                                            <Button Classes="ghost" FontSize="11" Padding="2,0" VerticalAlignment="Center" Click="OnInstallationHelpClick">?</Button>
                                        </StackPanel>
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="DQX Folder Path:"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <Border Grid.Column="1"
                                                    Background="{DynamicResource AppSurface}"
                                                    BorderBrush="{DynamicResource AppBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="6,3"
                                                    ClipToBounds="True"
                                                    Margin="0,0,6,0"
                                                    ToolTip.Tip="Path to your DQX installation folder.">
                                                <Panel>
                                                    <TextBlock Text="{Binding DqxDir}"
                                                               FontSize="12"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource AppText}"
                                                               IsVisible="{Binding DqxDir, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                    <TextBlock Text="No folder selected"
                                                               FontSize="12"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource AppMuted}"
                                                               IsVisible="{Binding DqxDir, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                                </Panel>
                                            </Border>
                                            <Button Grid.Column="2"
                                                    Command="{Binding ClearDqxDirCommand}"
                                                    IsVisible="{Binding DqxDir, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    ToolTip.Tip="Clear the DQX folder path."
                                                    Margin="0,0,6,0">C</Button>
                                            <Button Grid.Column="3"
                                                    x:Name="BrowseBtn"
                                                    Click="OnBrowseClick"
                                                    ToolTip.Tip="Browse for your DQX installation folder.">Browse...</Button>
                                        </Grid>
                                        <TextBlock Text="{Binding DqxDirError}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource AppDanger}"
                                                   TextWrapping="Wrap"
                                                   IsVisible="{Binding DqxDirError,
                                                               Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </StackPanel>
                                </Border>

                                <Border Classes="fieldset"
                                        IsVisible="{Binding DqxDirValid}">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,0">
                                            <TextBlock Classes="legend" Text="Patch" Margin="0" VerticalAlignment="Center"/>
                                            <Button Classes="ghost" FontSize="11" Padding="2,0" VerticalAlignment="Center" Click="OnPatchHelpClick">?</Button>
                                        </StackPanel>

                                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                                            <Button Grid.Column="0" Grid.Row="0" Margin="0,0,3,0"
                                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                    Command="{Binding PatchLauncherCommand}" IsEnabled="{Binding !Patching}"
                                                    ToolTip.Tip="Patch the Japanese launcher with an English version.">Patch Launcher</Button>
                                            <Button Grid.Column="1" Grid.Row="0" Margin="3,0,0,0"
                                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                    Command="{Binding RestoreLauncherCommand}" IsEnabled="{Binding !Patching}"
                                                    ToolTip.Tip="Restore the original Japanese launcher executable.">Restore Launcher</Button>

                                            <Button Grid.Column="0" Grid.Row="1" Margin="0,4,3,0"
                                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                    Command="{Binding PatchConfigCommand}" IsEnabled="{Binding !Patching}"
                                                    ToolTip.Tip="Patch the Japanese Config with an English version.">Patch Config</Button>
                                            <Button Grid.Column="1" Grid.Row="1" Margin="3,4,0,0"
                                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                    Command="{Binding RestoreConfigCommand}" IsEnabled="{Binding !Patching}"
                                                    ToolTip.Tip="Restore the original Japanese Config executable.">Restore Config</Button>

                                            <Button Grid.Column="0" Grid.Row="2" Margin="0,4,3,0"
                                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                    Command="{Binding PatchGameFilesCommand}" IsEnabled="{Binding !Patching}"
                                                    ToolTip.Tip="Download and apply the latest DAT/IDX translation mod. Requires admin. DQX must be closed.">Patch Game Files</Button>
                                            <Button Grid.Column="1" Grid.Row="2" Margin="3,4,0,0"
                                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                    Command="{Binding RestoreGameFilesCommand}" IsEnabled="{Binding !Patching}"
                                                    ToolTip.Tip="Restore the original game files. Requires admin. DQX must be closed.">Restore Game Files</Button>
                                        </Grid>

                                        <ProgressBar IsVisible="{Binding Patching}" Minimum="0" Maximum="100">
                                            <ProgressBar.Value>
                                                <MultiBinding Converter="{StaticResource PatchProgress}">
                                                    <Binding Path="PatchDownloaded"/>
                                                    <Binding Path="PatchTotal"/>
                                                </MultiBinding>
                                            </ProgressBar.Value>
                                        </ProgressBar>

                                        <TextBlock Text="{Binding PatchStatus}"
                                                   FontSize="11" TextWrapping="Wrap"
                                                   IsVisible="{Binding PatchStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                   Foreground="{Binding PatchIsError, Converter={x:Static v:BoolToBrushConverter.ErrorOrMuted}}"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>

                            <!-- ── Launch sub-panel ─────────────────────── -->
                            <StackPanel x:Name="PanelGameLaunch" Spacing="14" IsVisible="False">

                                <!-- Launch -->
                                <Border Classes="fieldset">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Classes="legend" Text="Launch" Margin="0" VerticalAlignment="Center"/>
                                            <Button Classes="ghost" FontSize="11" Padding="2,0" VerticalAlignment="Center" Click="OnLaunchHelpClick">?</Button>
                                        </StackPanel>
                                        <Grid ColumnDefinitions="*,*">
                                            <Button Grid.Column="0" Margin="0,0,3,0"
                                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                    Command="{Binding OpenDqxCommand}"
                                                    ToolTip.Tip="Launch DQXBoot.exe.">Open DQX Launcher</Button>
                                            <Button Grid.Column="1" Margin="3,0,0,0"
                                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                    Command="{Binding OpenDqxConfigCommand}"
                                                    ToolTip.Tip="Launch DQXConfig.exe.">Open DQXConfig</Button>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <CheckBox Content="Launch DQX Launcher with dqxclarity"
                                                      FontSize="11"
                                                      IsChecked="{Binding SimultaneousLaunch}"
                                                      ToolTip.Tip="Launch the official DQX launcher alongside dqxclarity."/>
                                            <CheckBox Content="Log into DQX directly with dqxclarity"
                                                      FontSize="11"
                                                      IsChecked="{Binding DirectLogin}"
                                                      ToolTip.Tip="Launch DQX with saved account information below and run dqxclarity."/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Accounts -->
                                <Border Classes="fieldset">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Classes="legend" Text="Accounts" Margin="0" VerticalAlignment="Center"/>
                                            <Button Classes="ghost" FontSize="11" Padding="2,0" VerticalAlignment="Center" Click="OnAccountsHelpClick">?</Button>
                                        </StackPanel>

                                        <!-- Selector row -->
                                        <Grid ColumnDefinitions="*,Auto,Auto" IsVisible="{Binding Accounts.Count,
                                              Converter={x:Static v:CountToBoolConverter.Instance}}">
                                            <ComboBox Grid.Column="0"
                                                      HorizontalAlignment="Stretch"
                                                      ItemsSource="{Binding Accounts}"
                                                      SelectedItem="{Binding SelectedAccount}"
                                                      ToolTip.Tip="The account to log into DQX with. Will prompt for MFA/OTP if present.">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate x:DataType="m:SavedPlayer">
                                                        <TextBlock Text="{Binding DisplayName}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <Button Grid.Column="1" Margin="6,0,0,0"
                                                    Command="{Binding ToggleAddAccountFormCommand}"
                                                    IsEnabled="{Binding !AddingAccount}"
                                                    ToolTip.Tip="Add a new account.">+</Button>
                                            <Button Grid.Column="2" Margin="4,0,0,0"
                                                    Classes="danger"
                                                    Command="{Binding DeleteAccountCommand}"
                                                    IsEnabled="{Binding CanDeleteSelectedAccount}"
                                                    ToolTip.Tip="Remove the selected account.">−</Button>
                                        </Grid>

                                        <!-- Easy Play warning -->
                                        <Border IsVisible="{Binding IsTrialAccountSelected}"
                                                BorderBrush="{DynamicResource AppDanger}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="8,6">
                                            <TextBlock Text="Easy Play Accounts are not recommended to log in with. They're not tied to a Square Enix account and only exist on your local computer. In the event something happens to your computer, your save data will be unrecoverable!&#x0a;&#x0a;If you have previously linked your Square Enix account through Easy Play, you can ignore this warning and log in with this method as normal."
                                                       FontSize="11"
                                                       Foreground="{DynamicResource AppDanger}"
                                                       TextWrapping="Wrap"/>
                                        </Border>

                                        <!-- Empty state -->
                                        <StackPanel Orientation="Horizontal" Spacing="8"
                                                    IsVisible="{Binding Accounts.Count,
                                                                Converter={x:Static v:CountToBoolConverter.IsZeroInstance}}">
                                            <TextBlock Text="No accounts saved."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource AppMuted}"
                                                       VerticalAlignment="Center"/>
                                            <Button Command="{Binding ToggleAddAccountFormCommand}"
                                                    IsEnabled="{Binding !AddingAccount}">Add Account</Button>
                                        </StackPanel>

                                        <!-- Add account inline form -->
                                        <Border IsVisible="{Binding ShowAddAccountForm}"
                                                Background="{DynamicResource AppSurface}"
                                                BorderBrush="{DynamicResource AppBorder}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="10,8">
                                            <StackPanel Spacing="6">
                                                <TextBox Watermark="Username"
                                                         Text="{Binding NewAccountUsername}"
                                                         IsEnabled="{Binding !AddingAccount}"
                                                         IsVisible="{Binding !NewAccountNeedsOtp}"/>
                                                <TextBox Watermark="Password"
                                                         PasswordChar="•"
                                                         Text="{Binding NewAccountPassword}"
                                                         IsEnabled="{Binding !AddingAccount}"
                                                         IsVisible="{Binding !NewAccountNeedsOtp}"/>
                                                <TextBox Watermark="One-time password (6 digits)"
                                                         Text="{Binding NewAccountOtp}"
                                                         IsEnabled="{Binding !AddingAccount}"
                                                         IsVisible="{Binding NewAccountNeedsOtp}"/>
                                                <TextBlock Text="{Binding AddAccountError}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource AppDanger}"
                                                           TextWrapping="Wrap"
                                                           IsVisible="{Binding AddAccountError,
                                                                       Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Button Classes="accent"
                                                            Command="{Binding SubmitNewAccountCommand}"
                                                            IsEnabled="{Binding !AddingAccount}"
                                                            IsVisible="{Binding !NewAccountNeedsOtp}">Add Account</Button>
                                                    <Button Classes="accent"
                                                            Command="{Binding SubmitNewAccountOtpCommand}"
                                                            IsEnabled="{Binding !AddingAccount}"
                                                            IsVisible="{Binding NewAccountNeedsOtp}">Submit OTP</Button>
                                                    <Button Command="{Binding CancelAddAccountCommand}"
                                                            IsEnabled="{Binding !AddingAccount}">Cancel</Button>
                                                    <TextBlock Text="Verifying…"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource AppMuted}"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding AddingAccount}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                    </StackPanel>
                                </Border>

                            </StackPanel>

                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- ══ NAME OVERRIDES (full height) ══════════════════════ -->
                <Grid x:Name="PanelOverrides" IsVisible="False" Margin="14,12"
                      RowDefinitions="Auto,Auto,*">

                    <!-- Header row: save-error / success banners on left, buttons on right -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                        <Border Grid.Column="0"
                                BorderBrush="{DynamicResource AppDanger}"
                                BorderThickness="1" CornerRadius="4" Padding="8,6"
                                Background="{DynamicResource AppSurface2}"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                IsVisible="{Binding OverridesSaveError,
                                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding OverridesSaveError}"
                                       FontSize="11"
                                       Foreground="{DynamicResource AppDanger}"
                                       TextWrapping="Wrap"/>
                        </Border>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Top">
                            <TextBlock Text="Saved!"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource AppSuccess}"
                                       IsVisible="{Binding OverridesSaveSuccess}"/>
                            <Button Click="OnNameOverridesHelpClick">Help</Button>
                            <Button Classes="accent"
                                    Command="{Binding SaveNameOverridesCommand}">Save</Button>
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Text="Preferred names are limited to 12 characters due to in-game limitations."
                               FontSize="11"
                               Foreground="{DynamicResource AppMuted}"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap"/>

                    <!-- Two-column name pair editor -->
                    <Grid Grid.Row="2" ColumnDefinitions="*,1,*">

                        <!-- Left: Player Names -->
                        <DockPanel Grid.Column="0">
                            <StackPanel DockPanel.Dock="Top"
                                        Orientation="Horizontal"
                                        Spacing="6"
                                        Margin="0,0,0,6">
                                <TextBlock Text="Player Names"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button Command="{Binding AddPlayerNameCommand}"
                                        Padding="6,2">+</Button>
                            </StackPanel>
                            <Grid DockPanel.Dock="Top"
                                  ColumnDefinitions="*,*,Auto"
                                  Margin="0,0,0,4">
                                <TextBlock Grid.Column="0"
                                           Text="Japanese"
                                           FontSize="11"
                                           Foreground="{DynamicResource AppMuted}"
                                           Padding="6,0"/>
                                <TextBlock Grid.Column="1"
                                           Text="Preferred"
                                           FontSize="11"
                                           Foreground="{DynamicResource AppMuted}"
                                           Padding="6,0"/>
                            </Grid>
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding PlayerNames}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:NamePair">
                                            <Grid ColumnDefinitions="*,*,Auto" Margin="0,0,0,4">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding Japanese}"
                                                         MaxLength="12"
                                                         FontSize="12"
                                                         Watermark="Japanese"
                                                         Margin="0,0,4,0"/>
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding Preferred}"
                                                         MaxLength="12"
                                                         FontSize="12"
                                                         Watermark="Preferred"
                                                         Margin="0,0,4,0"/>
                                                <Button Grid.Column="2"
                                                        Command="{Binding RemoveCommand}"
                                                        Padding="4,2">x</Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>

                        <!-- Divider -->
                        <Border Grid.Column="1"
                                Background="{DynamicResource AppBorder}"
                                Margin="8,0"/>

                        <!-- Right: Mytown Names -->
                        <DockPanel Grid.Column="2" Margin="8,0,0,0">
                            <StackPanel DockPanel.Dock="Top"
                                        Orientation="Horizontal"
                                        Spacing="6"
                                        Margin="0,0,0,6">
                                <TextBlock Text="Mytown Names"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button Command="{Binding AddMytownNameCommand}"
                                        Padding="6,2">+</Button>
                            </StackPanel>
                            <Grid DockPanel.Dock="Top"
                                  ColumnDefinitions="*,*,Auto"
                                  Margin="0,0,0,4">
                                <TextBlock Grid.Column="0"
                                           Text="Japanese"
                                           FontSize="11"
                                           Foreground="{DynamicResource AppMuted}"
                                           Padding="6,0"/>
                                <TextBlock Grid.Column="1"
                                           Text="Preferred"
                                           FontSize="11"
                                           Foreground="{DynamicResource AppMuted}"
                                           Padding="6,0"/>
                            </Grid>
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding MytownNames}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:NamePair">
                                            <Grid ColumnDefinitions="*,*,Auto" Margin="0,0,0,4">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding Japanese}"
                                                         MaxLength="12"
                                                         FontSize="12"
                                                         Watermark="Japanese"
                                                         Margin="0,0,4,0"/>
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding Preferred}"
                                                         MaxLength="12"
                                                         FontSize="12"
                                                         Watermark="Preferred"
                                                         Margin="0,0,4,0"/>
                                                <Button Grid.Column="2"
                                                        Command="{Binding RemoveCommand}"
                                                        Padding="4,2">x</Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Grid>
                </Grid>

                <!-- ══ LANGUAGE PACKS (full height) ═════════════════════ -->
                <Grid x:Name="PanelLanguagePacks" IsVisible="False" Margin="14,8"
                      RowDefinitions="Auto,Auto,*">

                    <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,Auto,*" Margin="0,0,0,10">
                        <Button Grid.Column="0"
                                Command="{Binding ScanLanguagePacksCommand}"
                                IsEnabled="{Binding !LanguagePacksLoading}"
                                ToolTip.Tip="Scans the language packs folder in the dqxclarity directory."
                                Margin="0,0,10,0">Scan Folder</Button>
                        <Button Grid.Column="1"
                                Command="{Binding OpenLanguagePacksFolderCommand}"
                                ToolTip.Tip="Opens the dqxclarity language packs folder."
                                Margin="0,0,10,0">Open Language Packs Folder</Button>
                        <Button Grid.Column="2"
                                Command="{Binding CheckLanguagePackUpdatesCommand}"
                                IsEnabled="{Binding !LanguagePacksLoading}"
                                ToolTip.Tip="Downloads each language pack's download_url and compares its mod.jsons version."
                                Margin="0,0,10,0">Check Updates</Button>
                        <CheckBox Grid.Column="3"
                                  Content="Activate Language Pack support"
                                  IsChecked="{Binding LanguagePackSupport}"
                                  VerticalAlignment="Center"
                                  ToolTip.Tip="Copies version.dll into the DQX Game folder when enabled, and removes it when disabled."/>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Text="{Binding LanguagePackStatus}"
                               FontSize="11"
                               Foreground="{DynamicResource AppMuted}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"
                               IsVisible="{Binding !LanguagePackStatusIsError}"/>
                    <TextBlock Grid.Row="1"
                               Text="{Binding LanguagePackStatus}"
                               FontSize="11"
                               Foreground="{DynamicResource AppDanger}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"
                               IsVisible="{Binding LanguagePackStatusIsError}"/>

                    <Border Grid.Row="2"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8"
                            Background="{DynamicResource AppSurface}">
                        <Grid RowDefinitions="Auto,*">
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="34,120,3*,120,120,2*"
                                  Background="{DynamicResource AppSurface2}">
                                <TextBlock Grid.Column="1"
                                           Text="type"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppMuted}"
                                           Padding="8,4"/>
                                <TextBlock Grid.Column="2"
                                           Text="name"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppMuted}"
                                           Padding="8,4"/>
                                <TextBlock Grid.Column="3"
                                           Text="version"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppMuted}"
                                           Padding="8,4"/>
                                <TextBlock Grid.Column="4"
                                           Text="author"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppMuted}"
                                           Padding="8,4"/>
                                <TextBlock Grid.Column="5"
                                           Text="status"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppMuted}"
                                           Padding="8,4"/>
                            </Grid>

                            <ScrollViewer Grid.Row="1"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding LanguagePacks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="m:LanguagePack">
                                            <Border BorderBrush="{DynamicResource AppBorder}"
                                                    BorderThickness="0,0,0,1">
                                                <Grid ColumnDefinitions="34,120,3*,120,120,2*">
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{Binding IsActive}"
                                                              IsEnabled="{Binding CanActivate}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Click="OnLanguagePackActiveClick"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Type}"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource AppText}"
                                                               Padding="8,4"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Name}"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource AppText}"
                                                               Padding="8,4"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding Version}"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource AppText}"
                                                               Padding="8,4"
                                                               IsVisible="{Binding !HasUpdate}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Button Grid.Column="3"
                                                            IsVisible="{Binding HasUpdate}"
                                                            Click="OnLanguagePackUpdateClick"
                                                            FontSize="11"
                                                            HorizontalAlignment="Left"
                                                            Padding="8,2"
                                                            Margin="8,2">DL update</Button>
                                                    <TextBlock Grid.Column="4"
                                                               Text="{Binding Author}"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource AppText}"
                                                               Padding="8,4"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="5"
                                                               Text="{Binding Status}"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource AppMuted}"
                                                               Padding="8,4"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ══ DATABASE (full height) ════════════════════════════ -->
                <Grid x:Name="PanelDatabase" IsVisible="False" Margin="14,8"
                      RowDefinitions="Auto,Auto,Auto,*,Auto">

                    <!-- Toolbar row 1 -->
                    <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto" Margin="0,0,0,6">
                        <Button Grid.Column="0"
                                Command="{Binding ReadDatabaseCommand}"
                                IsEnabled="{Binding !DbLoading}"
                                x:Name="ReadDbBtn"
                                Margin="0,0,4,0">Read Database</Button>
                        <Button Grid.Column="1"
                                Margin="0,0,4,0"
                                Click="OnDbHelpClick">Help</Button>
                        <ComboBox Grid.Column="2"
                                  x:Name="DbTableCombo"
                                  Margin="0,0,4,0"
                                  IsEnabled="{Binding DbTables.Count,
                                              Converter={x:Static v:CountToBoolConverter.Instance}}"
                                  PlaceholderText="Select table…"
                                  ItemsSource="{Binding DbTables}"
                                  SelectionChanged="OnDbTableSelectionChanged"/>
                        <Button Grid.Column="3"
                                Classes="danger"
                                IsEnabled="{Binding DbTables.Count,
                                            Converter={x:Static v:CountToBoolConverter.Instance}}"
                                Click="OnPurgeClick">Purge Database</Button>
                    </Grid>

                    <!-- Toolbar row 2: filter + delete -->
                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                        <TextBox Grid.Column="0"
                                 Watermark="Filter rows…"
                                 Text="{Binding DbFilter}"
                                 IsEnabled="{Binding DbColumns.Count,
                                             Converter={x:Static v:CountToBoolConverter.Instance}}"
                                 Margin="0,0,6,0"/>
                        <Button Grid.Column="1"
                                Classes="danger"
                                x:Name="DeleteBtn"
                                IsEnabled="False"
                                IsVisible="{Binding DbSelectedTable,
                                            Converter={x:Static v:StringEqualConverter.Instance},
                                            ConverterParameter='dialog'}"
                                Click="OnDeleteClick">Delete</Button>
                    </Grid>

                    <!-- Error text -->
                    <TextBlock Grid.Row="2"
                               Text="{Binding DbError}"
                               FontSize="11"
                               Foreground="{DynamicResource AppDanger}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4"
                               IsVisible="{Binding DbError,
                                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <!-- Custom table: virtual scrolling + synced header -->
                    <Border Grid.Row="3"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            ClipToBounds="True">
                        <Grid RowDefinitions="Auto,*">
                            <!-- Header scrolls horizontally in sync with content; bar is hidden -->
                            <Border Grid.Row="0"
                                    Background="{DynamicResource AppSurface2}"
                                    BorderBrush="{DynamicResource AppBorder}"
                                    BorderThickness="0,0,0,1">
                                <ScrollViewer x:Name="DbHeaderScroll"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Disabled">
                                    <Grid x:Name="DbHeaderRow" Height="26"/>
                                </ScrollViewer>
                            </Border>
                            <!-- Content: virtual canvas inside a full-scroll viewer -->
                            <ScrollViewer Grid.Row="1"
                                          x:Name="DbScroll"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          AllowAutoHide="False"
                                          Background="{DynamicResource AppSurface}"
                                          ScrollChanged="OnDbScrollChanged">
                                <Canvas x:Name="DbCanvas"
                                        VerticalAlignment="Top"
                                        HorizontalAlignment="Left"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Row count -->
                    <TextBlock Grid.Row="4"
                               Text="{Binding DbRowCount}"
                               FontSize="11"
                               Foreground="{DynamicResource AppMuted}"
                               Margin="0,4,0,0"
                               IsVisible="{Binding DbRowCount,
                                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </Grid>

                <Grid x:Name="PanelText2Clipboard"
                      IsVisible="False"
                      Margin="14,12"
                      RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0"
                               IsVisible="{Binding !DirectLogin}"
                               Text="Native copy/paste support only works when &quot;Log into DQX directly with dqxclarity&quot; is enabled! This can be configured under Game > Launch."
                               FontSize="11"
                               Foreground="{DynamicResource AppDanger}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                    <ContentControl Grid.Row="1"
                                    Content="{Binding Text2Clipboard}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate DataType="vm:Text2ClipboardViewModel">
                                <v:Text2ClipboardView/>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </Grid>

            </Grid>
        </Grid>

        <!-- ── Bottom bar ─────────────────────────────────────────────── -->
        <Border Grid.Column="1" Grid.Row="1"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="0,1,0,0"
                Padding="14,8">
            <Grid ColumnDefinitions="*,Auto">

                <Grid Grid.Column="0"
                      ColumnDefinitions="Auto,*"
                      VerticalAlignment="Center">
                    <Button Grid.Column="0"
                            Classes="accent"
                            Padding="12,5"
                            Click="OnUpdateClick"
                            Content="{Binding UpdateButtonText}"
                            IsVisible="{Binding UpdateInfo, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding UpdateBarText}"
                               FontSize="13"
                               Foreground="{DynamicResource AppMuted}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                </Grid>

                <Button Grid.Column="1"
                        Classes="accent"
                        Padding="16,5"
                        FontWeight="SemiBold"
                        Command="{Binding RunCommand}"
                        ToolTip.Tip="Save settings and launch dqxclarity.">Run</Button>
            </Grid>
        </Border>

    </Grid>

</UserControl>
