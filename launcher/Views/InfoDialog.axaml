<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DqxClarity.Launcher.Views.InfoDialog"
             Width="460">
    <Border Background="{DynamicResource AppBg}"
            CornerRadius="8"
            Padding="20,18,20,20">
        <StackPanel Spacing="12">
            <TextBlock x:Name="TitleText"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource AppAccent}"
                       TextWrapping="Wrap"/>
            <TextBlock x:Name="BodyText"
                       FontSize="12"
                       Foreground="{DynamicResource AppText}"
                       TextWrapping="Wrap"
                       LineHeight="18"/>
            <Button Classes="accent"
                    HorizontalAlignment="Right"
                    Padding="16,5"
                    Click="OnOk">OK</Button>
        </StackPanel>
    </Border>
</UserControl>
