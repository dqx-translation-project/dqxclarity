<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DqxClarity.Launcher.Views.SupportPopup"
             Width="380">
    <Border Background="{DynamicResource AppSurface2}"
            CornerRadius="8"
            Padding="18,14">
        <StackPanel Spacing="14">
            <TextBlock Text="Support"
                       FontWeight="SemiBold"
                       FontSize="13"
                       Foreground="{DynamicResource AppText}"/>

            <TextBlock Text="For help with dqxclarity, please open an issue on GitHub. Only program-specific help is provided."
                       FontSize="12"
                       Foreground="{DynamicResource AppMuted}"
                       TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button x:Name="GithubBtn"
                        Click="OnGithubClick">Open GitHub Issues</Button>
                <Button Padding="16,5"
                        Click="OnClose">Close</Button>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
