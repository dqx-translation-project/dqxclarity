<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DqxClarity.Launcher.Views.UacDialog"
             Width="360">
    <Border Background="{DynamicResource AppSurface2}"
            CornerRadius="8"
            Padding="18,14">
        <StackPanel Spacing="12">
            <TextBlock Text="Administrator permission required"
                       FontWeight="SemiBold"
                       FontSize="13"
                       Foreground="{DynamicResource AppText}"/>
            <TextBlock FontSize="12"
                       Foreground="{DynamicResource AppMuted}"
                       TextWrapping="Wrap"
                       LineHeight="18">
                Windows is asking for permission to install Python. Click <Run FontWeight="Bold" Foreground="{DynamicResource AppText}">Yes</Run> on the prompt to continue, then click OK.
            </TextBlock>
            <Button Classes="accent"
                    HorizontalAlignment="Right"
                    Padding="16,5"
                    Click="OnOk">OK</Button>
        </StackPanel>
    </Border>
</UserControl>
