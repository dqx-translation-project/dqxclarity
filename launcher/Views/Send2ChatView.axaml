<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DqxClarity.Launcher.ViewModels"
             x:Class="DqxClarity.Launcher.Views.Send2ChatView"
             x:DataType="vm:Send2ChatViewModel"
             Background="{DynamicResource AppBg}">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="14" HorizontalAlignment="Stretch" MaxWidth="720">
            <Border Classes="fieldset">
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Bottom"
                            Classes="accent"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Margin="0,8,0,0"
                            Command="{Binding CopySelectedQuestCommand}">Copy to clipboard</Button>
                    <StackPanel Spacing="8">
                        <TextBlock Classes="legend" Text="Quest"/>
                        <ComboBox HorizontalAlignment="Stretch"
                                  MaxWidth="300"
                                  ItemsSource="{Binding QuestKeys}"
                                  SelectedItem="{Binding SelectedQuestKey}"
                                  PlaceholderText="Select quest...">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="Preview"
                                   FontSize="11"
                                   Foreground="{DynamicResource AppMuted}"/>
                        <Border Background="{DynamicResource AppSurface2}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8,6">
                            <SelectableTextBlock Text="{Binding Preview}"
                                                 TextWrapping="Wrap"
                                                 FontSize="13"/>
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Classes="fieldset">
                <StackPanel Spacing="8">
                    <TextBlock Classes="legend" Text="Common phrases"/>
                    <TextBlock Text="Tap a phrase to copy it to clipboard."
                               FontSize="11"
                               Foreground="{DynamicResource AppMuted}"/>
                    <ItemsControl ItemsSource="{Binding CommonPhrases}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,6,6"
                                        FontSize="12"
                                        Command="{Binding DataContext.CopyPhraseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Key}"
                                        Content="{Binding Key}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding Status}"
                       FontSize="11"
                       Foreground="{DynamicResource AppMuted}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
