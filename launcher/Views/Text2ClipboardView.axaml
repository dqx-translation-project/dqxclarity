<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DqxClarity.Launcher.ViewModels"
             xmlns:conv="using:DqxClarity.Launcher.Views"
             x:Class="DqxClarity.Launcher.Views.Text2ClipboardView"
             x:DataType="vm:Text2ClipboardViewModel"
             Background="{DynamicResource AppBg}">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="14" HorizontalAlignment="Stretch" MaxWidth="720">

            <!-- ══ QUEST ════════════════════════════════════════════════ -->
            <Border Classes="fieldset">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Classes="legend" Text="Quest" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding QuestStatus}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMuted}"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="240,*,Auto">
                        <ComboBox Grid.Column="0"
                                  HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding QuestKeys}"
                                  SelectedItem="{Binding SelectedQuestKey}"
                                  PlaceholderText="Select quest...">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Border Grid.Column="2"
                                Background="{DynamicResource AppSurface2}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8,6"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                            <SelectableTextBlock Text="{Binding Preview}"
                                                 TextWrapping="NoWrap"
                                                 FontSize="13"
                                                 VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ══ COMMON PHRASES ═══════════════════════════════════════ -->
            <Border Classes="fieldset">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Classes="legend" Text="Common phrases" Margin="0" VerticalAlignment="Center"/>
                        <Button Classes="ghost" FontSize="11" Padding="2,0" VerticalAlignment="Center" Click="OnCommonPhrasesHelpClick">?</Button>
                        <TextBlock Text="{Binding PhrasesStatus}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0"
                                   Foreground="{DynamicResource AppMuted}"/>
                    </StackPanel>

                    <!-- Pinned quick-access buttons: 5 per row, equal-width, label truncated to 20 chars -->
                    <ItemsControl ItemsSource="{Binding PinnedButtons}"
                                  IsVisible="{Binding HasPins}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="5"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PinnedEntry">
                                <Button Margin="0,0,6,6"
                                        FontSize="12"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        ToolTip.Tip="{Binding TooltipText}"
                                        DragDrop.AllowDrop="True"
                                        Command="{Binding DataContext.SelectPinCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Identifier}">
                                    <TextBlock Text="{Binding Identifier, Converter={x:Static conv:StringTruncateConverter.Instance}, ConverterParameter=20}"
                                               TextTrimming="CharacterEllipsis"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Dropdown + pin/delete controls -->
                    <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,2,0,0">
                        <ComboBox Grid.Column="0"
                                  HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding DropdownItems}"
                                  SelectedItem="{Binding SelectedPhrase}"
                                  PlaceholderText="Select a phrase...">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:PhraseEntry">
                                    <Grid>
                                        <TextBlock Text="{Binding Identifier}"
                                                   IsVisible="{Binding !IsDivider}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Separator IsVisible="{Binding IsDivider}"
                                                   Margin="0,2"/>
                                    </Grid>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="1"
                                Margin="6,0,0,0"
                                MinWidth="72"
                                Classes="accent"
                                HorizontalContentAlignment="Center"
                                Command="{Binding PinToggleCommand}"
                                Content="{Binding PinButtonLabel}"/>
                        <Button Grid.Column="2"
                                Margin="6,0,0,0"
                                Classes="danger"
                                HorizontalContentAlignment="Center"
                                Command="{Binding DeleteCustomCommand}"
                                Content="Delete"/>
                    </Grid>

                    <!-- Fixed add-new-phrase row -->
                    <Border BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="0,1,0,0"
                            Margin="0,8,0,0"
                            Padding="0,8,0,0">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Add a custom phrase"
                                       FontSize="11"
                                       Foreground="{DynamicResource AppMuted}"/>
                            <Grid ColumnDefinitions="*,*,Auto">
                                <TextBox Grid.Column="0"
                                         Text="{Binding NewIdentifier}"
                                         FontSize="12"
                                         Watermark="Identifier"
                                         Margin="0,0,4,0"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding NewJapanese}"
                                         FontSize="12"
                                         Watermark="Japanese"
                                         Margin="0,0,4,0"/>
                                <Button Grid.Column="2"
                                        Command="{Binding AddCustomPhraseCommand}"
                                        Padding="10,2">+</Button>
                            </Grid>
                            <Border BorderBrush="{DynamicResource AppDanger}"
                                    BorderThickness="1" CornerRadius="4" Padding="8,6"
                                    Background="{DynamicResource AppSurface2}"
                                    Margin="0,4,0,0"
                                    IsVisible="{Binding PhrasesSaveError,
                                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding PhrasesSaveError}"
                                           FontSize="11"
                                           Foreground="{DynamicResource AppDanger}"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
