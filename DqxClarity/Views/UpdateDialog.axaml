<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DqxClarity.Views.UpdateDialog"
             Width="460">
    <Border Background="{DynamicResource AppSurface2}"
            CornerRadius="8"
            Padding="18,14">
        <Grid RowDefinitions="Auto,260,Auto">
            <TextBlock Grid.Row="0"
                       x:Name="HeaderText"
                       FontWeight="SemiBold"
                       FontSize="13"
                       Foreground="{DynamicResource AppText}"
                       Margin="0,0,0,10"/>

            <ScrollViewer Grid.Row="1"
                          Background="{DynamicResource AppSurface}"
                          Padding="8"
                          CornerRadius="4"
                          Margin="0,0,0,12"
                          HorizontalScrollBarVisibility="Disabled">
                <SelectableTextBlock x:Name="BodyText"
                                     FontSize="11"
                                     Foreground="{DynamicResource AppText}"
                                     TextWrapping="Wrap"/>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button Click="OnLater">Later</Button>
                <Button Classes="accent" Click="OnUpdate">Update</Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
