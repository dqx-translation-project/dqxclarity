<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DqxClarity.Views.ConfirmDialog"
             Width="340">
    <Border Background="{DynamicResource AppSurface2}"
            CornerRadius="8"
            Padding="18,14">
        <StackPanel Spacing="14">
            <TextBlock x:Name="TitleText"
                       FontWeight="SemiBold"
                       FontSize="13"
                       Foreground="{DynamicResource AppText}"/>
            <TextBlock x:Name="BodyText"
                       FontSize="12"
                       Foreground="{DynamicResource AppMuted}"
                       TextWrapping="Wrap"
                       LineHeight="18"/>
            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Right">
                <Button x:Name="CancelBtn" Click="OnCancel">Cancel</Button>
                <Button x:Name="OkBtn" Classes="accent" Click="OnOk">OK</Button>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
