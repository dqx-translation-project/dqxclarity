<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DqxClarity.Views.SupportPopup"
             Width="380">
    <Border Background="{DynamicResource AppSurface2}"
            CornerRadius="8"
            Padding="18,14">
        <StackPanel Spacing="14">
            <TextBlock Text="Support"
                       FontWeight="SemiBold"
                       FontSize="13"
                       Foreground="{DynamicResource AppText}"/>

            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto">
                <TextBlock Grid.Column="0"
                           Text="Discord:"
                           FontSize="12"
                           Foreground="{DynamicResource AppMuted}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBox Grid.Column="1"
                         x:Name="DiscordBox"
                         IsReadOnly="True"
                         FontSize="11"
                         Text="https://discord.gg/dragonquestx"/>
                <Button Grid.Column="2"
                        x:Name="CopyBtn"
                        Margin="6,0,0,0"
                        Click="OnCopy">Copy</Button>
            </Grid>

            <Button HorizontalAlignment="Right"
                    Padding="16,5"
                    Click="OnClose">Close</Button>
        </StackPanel>
    </Border>
</UserControl>
